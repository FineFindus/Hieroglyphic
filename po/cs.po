msgstr "Žádné symboly"

#: data/resources/ui/window.ui:151 data/resources/ui/window.ui:243
msgid "Start by drawing a symbol"
msgstr "Začněte načrtnutím symbolu"

#: data/resources/ui/window.ui:183
