msgid "Hieroglyphic"
msgstr "Хијероглифик"

#: data/io.github.finefindus.Hieroglyphic.desktop.in.in:3
msgid "Search through over 1000 different LaTeX symbols by sketching"
msgstr "Скицирањем тражите у преко 1000 различитих LaTeX симбола"

#. Translators: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/io.github.finefindus.Hieroglyphic.desktop.in.in:9
msgid "GTK;Tools;LaTeX;TeX;Symbols;"
msgstr "Гтк;алати;ЛаТеХ;ТеХ;симболи;GTK;Tools;LaTeX;TeX;Symbols;"

#. Translators: nudge means here a gentle prompt, i.e. the colored dot on the button
#: data/io.github.finefindus.Hieroglyphic.gschema.xml.in:7
msgid "Whether to show a small nudge towards the contribution dialog"
msgstr "Да ли ће да покаже мали помак ка прозорчету доприношења"

#: data/io.github.finefindus.Hieroglyphic.gschema.xml.in:11
msgid "Whether to contribute recognized strokes"
msgstr "Да ли ће да допринесе препознате потезе"

#. Translators: the name of the markup language (latex, typst) for which symbols are suggested
#: data/io.github.finefindus.Hieroglyphic.gschema.xml.in:21
msgid "Markup language to suggest symbols for"
msgstr "Језик означавања за који се предлажу симболи"

#: data/io.github.finefindus.Hieroglyphic.metainfo.xml.in.in:9
msgid "Find LaTeX and Typst symbols"
msgstr "Нађите LaTeX и Typst симболе"

#: data/io.github.finefindus.Hieroglyphic.metainfo.xml.in.in:18
#| msgid ""
#| "If you work with LaTeX, you know it's difficult to memorize the names of "
#| "all the symbols. Hieroglyphic allows you to search through over 1000 "
#| "different LaTeX symbols by sketching."
msgid ""
"If you work with LaTeX or Typst, you know it's difficult to memorize the "
"names of all the symbols. Hieroglyphic allows you to search through over "
"1000 different symbols by sketching."
msgstr "Ако радите са ЛаТеКсом или Типстом, знате да је тешко запамтити називе свих симбола. Хијероглифик вам омогућава да претражујете преко 1000 различитих симбола цртањем."

#: data/io.github.finefindus.Hieroglyphic.metainfo.xml.in.in:30
#| msgid "Find LaTeX symbols"
msgid "Symbol selection for LaTeX symbols"
msgstr "Избор симбола за ЛаТеКс симболе"

#: data/io.github.finefindus.Hieroglyphic.metainfo.xml.in.in:34
msgid "Symbol selection for Typst symbols"
msgstr "Избор симбола за Типст симболе"

#: data/io.github.finefindus.Hieroglyphic.metainfo.xml.in.in:38
msgid "Placeholder"
msgstr "Чувар места"

#: data/resources/ui/contribution-dialog.ui:6
#: data/resources/ui/contribution-dialog.ui:40 data/resources/ui/window.ui:284
msgid "Improve Hieroglyphic"
msgstr "Побољшајте Хијероглифик"

#: data/resources/ui/contribution-dialog.ui:51
msgid "Help make Hieroglyphic better at identifying symbols for everyone"
msgstr "Помозите да Хијероглифик буде бољи у препознавању симбола"

#: data/resources/ui/contribution-dialog.ui:62
msgid "Contribute Symbols"
msgstr "Допринесите симболима"

#: data/resources/ui/contribution-dialog.ui:63
msgid "Submit recognized drawings to Hieroglyphic’s dataset"
msgstr "Предајте препознате цртеже у скуп података Хијероглифика"

#: data/resources/ui/contribution-dialog.ui:71
msgid ""
"No personal identifiable information is collected. <a href=\"https://"
"github.com/FineFindus/Hieroglyphic/blob/main/PRIVACY_POLICY.md\">Privacy "
"policy</a>"
msgstr "Лични подаци који се могу идентификовати се не прикупљају. <a href=\"https://github.com/FineFindus/Hieroglyphic/blob/main/PRIVACY_POLICY.md\">Политика приватности</a>"

#: data/resources/ui/symbol-item.ui:45
msgid "Copy"
msgstr "Умножи"

